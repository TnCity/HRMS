@model IEnumerable<HRMS.Entities.Department>

<div class="container mt-4">
    <h2>Departments</h2>

    <a asp-action="Create" class="btn btn-primary mb-3">Add Department</a>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>Department Name</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model)
            {
                <tr>
                    <td>@d.DepartmentId</td>
                    <td>@d.DepartmentName</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@d.DepartmentId" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@d.DepartmentId" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>