@{
    ViewData["Title"] = "Manage Reports";
}

<div class="container mt-5">

    <h2 class="mb-4 text-center">📊 Manage Reports</h2>
    <br />

    <div class="row">

        <!-- Attendance Report -->
        <div class="col-md-4">
            <div class="card shadow p-4 text-center">
                <h4>Attendance Report</h4>
                <p>View employee attendance data</p>
                <a href="/Reports/AttendanceReport" class="btn btn-primary">
                    Open
                </a>
            </div>
        </div>

        <!-- Performance Report -->
        <div class="col-md-4">
            <div class="card shadow p-4 text-center">
                <h4>Performance Report</h4>
                <p>View employee performance</p>
                <a href="/Reports/PerformanceReport" class="btn btn-success">
                    Open
                </a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow- p-4 text-center">
                <h4 class="mb-2">Individual Report</h4>
                <p> View employee-wise performance</p>
                <a href="/Reports/IndividualPerformance" class="btn btn-primary w-100">
                    Open
                </a>

            </div>
        </div>

    </div>

</div>