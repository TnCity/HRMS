@model List<HRMS.web.Models.PerformanceVM>

<div class="container">

    <!-- 🔹 TITLE -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h3 class="mb-0">📊 Over-All Performance Report</h3>

        <a href="/Reports/IndividualPerformance" class="btn btn-primary">
            👤 Individual Report
        </a>

    </div>

    <!-- 🔹 SUMMARY CARDS -->
    <div class="row mb-4 text-center">

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Total Employees</h6>
                <h4>@ViewBag.TotalEmployees</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Top Performers</h6>
                <h4>@Model.Count(x => x.Rating >= 4)</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Average</h6>
                <h4>@Model.Count(x => x.Rating == 3)</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Low Performers</h6>
                <h4>@Model.Count(x => x.Rating <= 2)</h4>
            </div>
        </div>

    </div>

    <!-- 🔹 TABLE -->
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            Employee Performance
        </div>

        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Employee</th>
                        <th>Tasks</th>
                        <th>Leaves</th>
                        <th>Score</th>
                        <th>Rating</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        string badge = item.Status == "Good" ? "success"
                                     : item.Status == "Average" ? "warning"
                                     : "danger";

                        <tr>
                            <td class="fw-semibold">@item.EmployeeName</td>
                            <td>@item.TasksCompleted</td>
                            <td>@item.LeavesTaken</td>
                            <td>@item.ProductivityScore</td>
                            <td>@item.Rating ⭐</td>
                            <td>
                                <span class="badge bg-@badge">@item.Status</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* <!-- 🔹 CHART -->
    <div class="card shadow-sm mt-4">
        <div class="card-header bg-primary text-white">
            Performance Chart
        </div>

        <div class="card-body">
            <canvas id="performanceChart"></canvas>
        </div>
    </div> *@

</div>

<!-- 🔹 Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    fetch('/Reports/GetPerformanceData')
        .then(res => res.json())
        .then(data => {

            const labels = data.map(x => x.name);
            const ratings = data.map(x => x.rating);

            new Chart(document.getElementById('performanceChart'), {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Performance Rating',
                        data: ratings
                    }]
                }
            });

        });
</script>