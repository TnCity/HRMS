


                        @model List<HRMS.web.Models.PerformanceVM>

<div class="container mt-4">

    <!-- 🔹 HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">👤 Individual Performance Report</h3>

        <form method="get">
            <select name="empId" class="form-select shadow-sm"
                    onchange="this.form.submit()"
                    style="width:250px;">
                <option value="">-- Select Employee --</option>

                @foreach (var emp in ViewBag.Employees)
                {
                    <option value="@emp.Id"
                            selected="@(Context.Request.Query["empId"] == emp.Id.ToString() ? "selected" : null)">
                        @emp.Name
                    </option>
                }
            </select>
        </form>
    </div>

    @if (Model.Any())
    {
        <!-- 🔹 SUMMARY CARD -->
        <div class="card shadow-sm mb-4 border-0">
            <div class="card-body text-center">

                <div class="row">

                    <div class="col-md-3">
                        <div class="p-3 rounded bg-primary text-white">
                            <h6>Tasks</h6>
                            <h3>@Model.First().TasksCompleted</h3>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="p-3 rounded bg-danger text-white">
                            <h6>Leaves</h6>
                            <h3>@Model.First().LeavesTaken</h3>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="p-3 rounded bg-success text-white">
                            <h6>Score</h6>
                            <h3>@Model.First().ProductivityScore</h3>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="p-3 rounded bg-dark text-white">
                            <h6>Status</h6>
                            <h5>@Model.First().Status</h5>
                        </div>
                    </div>

                </div>

            </div>
        </div>

        <!-- 🔹 TABLE -->
        <div class="card shadow-sm mb-4 border-0">
            <div class="card-header text-white fw-semibold"
                 style="background: linear-gradient(45deg, #343a40, #212529);">
                Performance Details
            </div>

            <div class="table-responsive">
                <table class="table table-hover mb-0 text-center align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Employee</th>
                            <th>Tasks</th>
                            <th>Leaves</th>
                            <th>Score</th>
                            <th>Rating</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            string badge = item.Status == "Good" ? "success"
                                         : item.Status == "Average" ? "warning"
                                         : "danger";

                            <tr>
                                <td class="fw-semibold">@item.EmployeeName</td>
                                <td>@item.TasksCompleted</td>
                                <td>@item.LeavesTaken</td>
                                <td class="text-success fw-bold">@item.ProductivityScore</td>
                                <td>@item.Rating ⭐</td>
                                <td>
                                    <span class="badge bg-@badge">@item.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- 🔹 CHART -->
        <div class="card shadow-sm border-0">
            <div class="card-header text-white fw-semibold"
                 style="background: linear-gradient(45deg, #0d6efd, #6610f2);">
                📊 Performance Trend
            </div>

            <div class="card-body">
                <canvas id="empChart" height="100"></canvas>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center shadow-sm">
            Select an employee to view performance
        </div>
    }

</div>

<!-- 🔹 Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

@if (Model.Any())
{
<script>
    var data = @Html.Raw(Json.Serialize(ViewBag.MonthlyData));

    var labels = data.map(x =>
        new Date(x.year, x.month - 1).toLocaleString('default', { month: 'short' })
    );

    var tasks = data.map(x => x.tasksCompleted);
    var leaves = data.map(x => x.leavesTaken);
    var scores = data.map(x => x.score);

    new Chart(document.getElementById('empChart'), {
        type: 'line',
        data: {
            labels: labels,
            datasets: [
                {
                    label: 'Tasks',
                    data: tasks,
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13,110,253,0.1)',
                    tension: 0.4
                },
                {
                    label: 'Leaves',
                    data: leaves,
                    borderColor: '#dc3545',
                    backgroundColor: 'rgba(220,53,69,0.1)',
                    tension: 0.4
                },
                {
                    label: 'Score',
                    data: scores,
                    borderColor: '#198754',
                    backgroundColor: 'rgba(25,135,84,0.1)',
                    yAxisID: 'y1',
                    tension: 0.4
                }
            ]
        },
        options: {
            responsive: true,
            interaction: {
                mode: 'index',
                intersect: false
            },
            scales: {
                y: {
                    beginAtZero: true,
                    title: { display: true, text: 'Tasks / Leaves' }
                },
                y1: {
                    beginAtZero: true,
                    position: 'right',
                    grid: { drawOnChartArea: false },
                    title: { display: true, text: 'Score' }
                }
            }
        }
    });
</script>
}