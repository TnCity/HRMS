@{
    ViewData["Title"] = "Attendance Report";
}

<div class="container-fluid mt-4 p-4" style="background-color:#f4f6f9; min-height:100vh;">

    <h3 class="mb-3">📊 Attendance Report</h3>

    <!-- Filters -->
    <div class="d-flex gap-3 mb-4">

        <div class="w-25">
            <label class="form-label fw-semibold">Select Employee</label>
            <select id="empDropdown" class="form-select">
                <option value="">-- Select Employee --</option>
                @foreach (var emp in ViewBag.Employees)
                {
                    <option value="@emp.Id">@emp.Name (@emp.Id)</option>
                }
            </select>
        </div>

        <div class="w-25">
            <label class="form-label fw-semibold">Select Month</label>
            <select id="monthDropdown" class="form-select">
                @for (int i = 1; i <= 12; i++)
                {
                    <option value="@i">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)</option>
                }
            </select>
        </div>

        <div class="w-25">
            <label class="form-label fw-semibold">Select Year</label>
            <select id="yearDropdown" class="form-select">
                <option value="2025">2025</option>
                <option value="2026">2026</option>
            </select>
        </div>

    </div>

    <div class="row">

        <!-- Summary -->
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">Summary</div>
                <div class="card-body">
                    <div id="summary">Select filters to view data</div>
                </div>
            </div>
        </div>

        <!-- Chart -->
        <div class="col-md-9">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">Attendance Trend</div>
                <div class="card-body">
                    <canvas id="attendanceChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="card mt-4">
            <div class="card-header bg-dark text-white">
                Attendance Details
            </div>

            <div class="card-body">
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Login</th>
                            <th>Logout</th>
                            <th>Working Hours</th>
                            <th>Punches</th>
                        </tr>
                    </thead>
                    <tbody id="attendanceTableBody"></tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    let chart;

    // 🔥 Auto set current month/year
    const now = new Date();
    document.getElementById("monthDropdown").value = now.getMonth() + 1;
    document.getElementById("yearDropdown").value = now.getFullYear();

    function loadAttendance() {

        let empId = document.getElementById("empDropdown").value;
        let month = document.getElementById("monthDropdown").value;
        let year = document.getElementById("yearDropdown").value;

        if (!empId) return;

        document.getElementById("summary").innerHTML = "⏳ Loading...";

        fetch(`/Reports/GetEmployeeAttendance?empId=${empId}&month=${month}&year=${year}`)
            .then(res => res.json())
            .then(data => {

                if (!data || data.length === 0) {
                    document.getElementById("summary").innerHTML = "❌ No attendance data found";
                    document.getElementById("attendanceTableBody").innerHTML = "<tr><td colspan='6'>No data</td></tr>";
                    return;
                }

                let labels = data.map(x => x.date);

                let totalPresent = data.reduce((a, b) => a + b.present, 0);
                let totalAbsent = data.reduce((a, b) => a + b.absent, 0);
                let totalLeave = data.reduce((a, b) => a + b.leave, 0);
                let totalIncomplete = data.reduce((a, b) => a + b.incomplete, 0);

                let totalDays = totalPresent + totalAbsent + totalLeave + totalIncomplete;

                let percent = totalDays === 0 ? 0 : ((totalPresent / totalDays) * 100).toFixed(1);

                let attendanceTrend = data.map(x => {
                    if (x.present > 0) return 100;
                    if (x.incomplete > 0) return 50;
                    return 0;
                });

                document.getElementById("summary").innerHTML = `
                    <div class="mb-2 p-2 bg-success text-white">Present: ${totalPresent}</div>
                    <div class="mb-2 p-2 bg-danger text-white">Absent: ${totalAbsent}</div>
                    <div class="mb-2 p-2 bg-warning text-dark">Leave: ${totalLeave}</div>
                    <div class="mb-2 p-2 bg-secondary text-white">Incomplete: ${totalIncomplete}</div>
                    <hr/>
                    <b>Attendance:</b> ${percent}% <br/>
                    <b>Total Days:</b> ${totalDays}
                `;

                if (chart) chart.destroy();

                let ctx = document.getElementById("attendanceChart").getContext("2d");

                chart = new Chart(ctx, {
                    type: "line",
                    data: {
                        labels: labels,
                        datasets: [{
                            label: "Attendance %",
                            data: attendanceTrend,
                            borderColor: "#007bff",
                            fill: true,
                            tension: 0.2
                        }]
                    },
                    options: {
                        scales: {
                            y: {
                                beginAtZero: true,
                                max: 100
                            }
                        }
                    }
                });
            });

        loadDetails(empId, month, year);
    }

    async function loadDetails(empId, month, year) {

        const res = await fetch(`/Reports/GetAttendanceWithDetails?empId=${empId}&month=${month}&year=${year}`);
        const data = await res.json();

        if (!data || data.length === 0) {
            document.getElementById("attendanceTableBody").innerHTML =
                "<tr><td colspan='6'>No records found</td></tr>";
            return;
        }

        let html = "";

        data.forEach(d => {
            html += `
                <tr>
                    <td>${d.date}</td>
                    <td><span class="badge ${getStatusClass(d.status)}">${d.status}</span></td>
                    <td>${formatTime(d.login)}</td>
                    <td>${formatTime(d.logout)}</td>
                    <td>${formatHours(d.workingHours)}</td>
                    <td>${formatPunches(d.punches)}</td>
                </tr>
            `;
        });

        document.getElementById("attendanceTableBody").innerHTML = html;
    }

    function formatTime(time) {
        if (!time) return "-";
        return new Date(time).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }

    function formatHours(hours) {
        if (!hours) return "-";
        let h = Math.floor(hours);
        let m = Math.round((hours - h) * 60);
        return `${h}h ${m}m`;
    }

    function formatPunches(punches) {
        if (!punches || punches.length === 0) return "-";

        return punches.map(p =>
            `<span class="badge bg-secondary me-1">${p}</span>`
        ).join("");
    }

    function getStatusClass(status) {
        switch (status) {
            case "Present": return "bg-success";
            case "Absent": return "bg-danger";
            case "Incomplete": return "bg-warning text-dark";
            default: return "bg-secondary";
        }
    }

    document.getElementById("empDropdown").addEventListener("change", loadAttendance);
    document.getElementById("monthDropdown").addEventListener("change", loadAttendance);
    document.getElementById("yearDropdown").addEventListener("change", loadAttendance);
</script>