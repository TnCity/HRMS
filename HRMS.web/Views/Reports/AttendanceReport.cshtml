@{
    ViewData["Title"] = "Attendance Report";
}

<div class="container mt-4">

    <h3 class="mb-3">📊 Attendance Report</h3>

    <!-- Dropdown -->
    <div class="mb-4 w-50">
        <label class="form-label fw-semibold">Select Employee</label>
        <select id="empDropdown" class="form-select">
            <option value="">-- Select Employee --</option>
            @foreach (var emp in ViewBag.Employees)
            {
                <option value="@emp.Id">@emp.Name (@emp.Id)</option>
            }
        </select>
    </div>

    <!-- Summary -->
    <div id="summary" class="mb-3 fw-bold"></div>

    <!-- Chart -->
    <div class="card shadow-sm p-3">
        <canvas id="attendanceChart" height="100"></canvas>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    let chart;

    document.getElementById("empDropdown").addEventListener("change", function () {
    let empId = this.value;

    if (!empId) return;

    fetch(`/Reports/GetEmployeeAttendance?empId=${empId}`)
    .then(res => res.json())
    .then(data => {

    if (!data || data.length === 0) {
    document.getElementById("summary").innerHTML = "❌ No attendance data found";
    return;
    }

    let labels = data.map(x => x.date);
    let values = data.map(x => x.status);

    // 📊 Summary Calculation
    let present = values.filter(v => v === 1).length;
    let total = values.length;
    let percent = ((present / total) * 100).toFixed(1);

    document.getElementById("summary").innerHTML =
    `✅ Present: ${present} / ${total} days (${percent}%)`;

    if (chart) chart.destroy();

    let ctx = document.getElementById('attendanceChart').getContext('2d');

    chart = new Chart(ctx, {
    type: 'bar',
    data: {
    labels: labels,
    datasets: [{
    label: 'Attendance',
    data: values,
    backgroundColor: values.map(v => v === 1 ? '#28a745' : '#dc3545'),
    borderRadius: 5
    }]
    },
    options: {
    responsive: true,
    plugins: {
    legend: {
    display: false
    },
    tooltip: {
    callbacks: {
    label: function (context) {
    return context.raw === 1 ? 'Present' : 'Absent';
    }
    }
    }
    },
    scales: {
    y: {
    beginAtZero: true,
    ticks: {
    stepSize: 1,
    callback: function (value) {
    return value === 1 ? 'Present' : 'Absent';
    }
    }
    }
    }
    }
    });
    });
    });
</script>