@model HRMS.Entities.Admin

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg p-4 rounded-4" style="width: 450px;">

        <div class="text-center mb-4">
            <h3 class="fw-bold text-success">Admin Registration</h3>
            <p class="text-muted">Create your account</p>
        </div>

        <form method="post" asp-action="Register">

            <!-- Email -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Email</label>
                <input type="email" asp-for="EmailId" class="form-control rounded-3" placeholder="Enter email" required />
            </div>

            <!-- Password -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Password</label>
                <input type="password" asp-for="Password" class="form-control rounded-3" placeholder="Enter password" required />
            </div>

            <!-- Confirm Password -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Confirm Password</label>
                <input type="password" name="ConfirmPassword" class="form-control rounded-3" placeholder="Confirm password" required />
            </div>

            <!-- Button -->
            <button type="submit" class="btn btn-success w-100 rounded-3">
                Register
            </button>

            <!-- Message -->
            @if (ViewBag.Message != null)
            {
                <div class="mt-3 text-center text-success">
                    @ViewBag.Message
                </div>
            }

            <!-- Login Link -->
            <p class="text-center mt-3">
                Already have an account?
                <a href="/Admin/Login" class="text-decoration-none fw-semibold text-primary">
                    Login
                </a>
            </p>

        </form>

    </div>
</div>