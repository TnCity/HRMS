@model HRMS.Entities.Admin

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg p-4 rounded-4" style="width: 400px;">

        <div class="text-center mb-4">
            <h3 class="fw-bold text-primary">Admin Login</h3>
            <p class="text-muted">Access your dashboard</p>
        </div>

        <form method="post" asp-action="Login">
            
            <div class="mb-3">
                <label class="form-label fw-semibold">Email</label>
                <input type="email" asp-for="EmailId" class="form-control rounded-3" placeholder="Enter email" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Password</label>
                <input type="password" asp-for="Password" class="form-control rounded-3" placeholder="Enter password" required />
            </div>

            <button type="submit" class="btn btn-primary w-100 rounded-3">
                Login
            </button>
            <div class="text-center mt-3">
                <span class="text-muted">Don't have an account?</span>
                <a asp-controller="Admin" asp-action="Register" class="fw-semibold text-decoration-none">
                    Register now
                </a>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="text-danger mt-3 text-center">
                    @ViewBag.Error
                </div>
            }

        </form>

    </div>
</div>