@model List<HRMS.web.Models.AttendanceDetailVM>
@using System.Linq

@{
    var presentCount = Model.Count(a => a.Status == "Present");
    var absentCount = Model.Count(a => a.Status == "Absent");
    var incompleteCount = Model.Count(a => a.Status == "Incomplete");
}

<div class="container mt-4">

    <h3 class="mb-4">📅 My Attendance</h3>

    <!-- 🔹 SUMMARY CARDS -->
    <div class="row text-center mb-4">
        <div class="col-md-3">
            <div class="card p-3 shadow">
                <h6>Total Days</h6>
                <h4>@Model.Count</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow">
                <h6>Present</h6>
                <h4 class="text-success">@presentCount</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow">
                <h6>Absent</h6>
                <h4 class="text-danger">@absentCount</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow">
                <h6>Incomplete</h6>
                <h4 class="text-warning">@incompleteCount</h4>
            </div>
        </div>
    </div>

    <!-- 🔹 GRAPH -->
    <div class="card shadow p-4 mb-4 text-center">
        <h5 class="mb-3">Attendance Summary</h5>

        <div style="width: 300px; height: 300px; margin: auto;">
            <canvas id="attendanceChart"></canvas>
        </div>
    </div>

    <!-- 🔹 TABLE (UPDATED) -->
    <table class="table table-bordered table-hover shadow">
        <thead class="table-dark">
            <tr>
                <th>Date</th>
                <th>Status</th>
                <th>Login</th>
                <th>Logout</th>
                <th>Working Hours</th>
                <th>Punches</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var a in Model)
            {
                <tr>
                    <td>@a.Date.ToString("dd MMM yyyy")</td>

                    <td>
                        @if (a.Status == "Present")
                        {
                            <span class="badge bg-success">Present</span>
                        }
                        else if (a.Status == "Incomplete")
                        {
                            <span class="badge bg-warning text-dark">Incomplete</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Absent</span>
                        }
                    </td>

                    <td>
                        @(a.Login != null ? ((DateTime)a.Login).ToString("hh:mm tt") : "-")
                    </td>

                    <td>
                        @(a.Logout != null ? ((DateTime)a.Logout).ToString("hh:mm tt") : "-")
                    </td>

                    <td>
                        @(a.WorkingHours != null ? a.WorkingHours + " hrs" : "-")
                    </td>

                    <td>
                        @if (a.Punches != null && a.Punches.Count > 0)
                        {
                            @string.Join(" → ", a.Punches)
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>

<!-- 🔹 CHART.JS -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    var ctx = document.getElementById('attendanceChart').getContext('2d');

    new Chart(ctx, {
    type: 'doughnut',
    data: {
    labels: ['Present', 'Absent', 'Incomplete'],
    datasets: [{
    data: [@presentCount, @absentCount, @incompleteCount]
    }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false
    }
    });
</script>