@model HRMS.Entities.Employee

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-5">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h3 class="fw-bold mb-0">Employee Registration</h3>
                    <small class="text-muted">Fill in the details to add a new employee</small>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back</a>
            </div>

            <hr />

            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <!-- Personal Info -->
                <h6 class="text-primary mb-3">Personal Information</h6>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Full Name</label>
                        <input asp-for="Name" class="form-control" placeholder="Enter full name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Email</label>
                        <!-- ✅ fixed -->
                        <input asp-for="Email" type="email" class="form-control" placeholder="Enter email address" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Phone</label>
                        <input asp-for="Phone" class="form-control" placeholder="Enter phone number" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Role</label>
                        <input asp-for="Role" class="form-control" placeholder="Enter role (e.g. Developer)" />
                    </div>
                </div>

                <!-- Job Info -->
                <h6 class="text-primary mt-4 mb-3">Job Details</h6>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Department</label>
                        <select asp-for="DepartmentId"
                                asp-items="@(ViewBag.Departments as SelectList)"
                                class="form-select">
                            <option value="">-- Select Department --</option>
                        </select>
                        <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Joining Date</label>
                        <input asp-for="JoinDate" type="date" class="form-control" />
                        <span asp-validation-for="JoinDate" class="text-danger small"></span>
                    </div>
                </div>

                <hr />
                <h6 class="text-primary">Additional Details</h6>

                <div class="row">
    
                    <!-- Profile Image -->
                    <div class="col-md-6 mb-3">
                        <label>Profile Photo</label>
                        <!-- ✅ fixed -->
                        <input type="file" name="ProfileImage" class="form-control" accept="image/*" />
                    </div>

                    <!-- Address -->
                    <div class="col-md-6 mb-3">
                        <label>Address</label>
                        <textarea asp-for="Address" class="form-control" placeholder="Enter address"></textarea>
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                </div>

                <div class="row">
    
                    <!-- Salary -->
                    <div class="col-md-6 mb-3">
                        <label>Salary</label>
                        <!-- ✅ fixed -->
                        <input asp-for="Salary" type="number" class="form-control" placeholder="Enter salary" />
                        <span asp-validation-for="Salary" class="text-danger"></span>
                    </div>

                    <!-- Designation -->
                    <div class="col-md-6 mb-3">
                        <label>Designation</label>
                        <input asp-for="Designation" class="form-control" placeholder="Enter designation" />
                        <span asp-validation-for="Designation" class="text-danger"></span>
                    </div>

                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-light border">Cancel</a>
                    <button type="submit" class="btn btn-success px-4">
                        Save Employee
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}