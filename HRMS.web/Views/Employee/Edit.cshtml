@model HRMS.Entities.Employee

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-5">

            <h3 class="fw-bold mb-4">Edit Employee</h3>

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="EmployeeId" />
                <input type="hidden" asp-for="ProfileImagePath" />

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row">

                    <!-- Left: Image -->
                    <div class="col-md-4 text-center mb-4">
                        <img src="@(string.IsNullOrEmpty(Model.ProfileImagePath)
                                                                                     ? Url.Content("~/images/default.png")
                                                                                     : Url.Content(Model.ProfileImagePath))"
                             class="img-fluid rounded shadow border"
                             style="height:300px; width:100%; object-fit:cover;" />

                        <div class="mt-3">
                            <input type="file" name="ProfileImage" class="form-control" />
                        </div>
                    </div>

                    <!-- Right: Form -->
                    <div class="col-md-8">

                        <div class="row">

                            <div class="col-md-6 mb-3">
                                <label>Name</label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label>Email</label>
                                <input asp-for="Email" class="form-control" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label>Phone</label>
                                <input asp-for="Phone" class="form-control" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label>Role</label>
                                <input asp-for="Role" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label>Department</label>
                                <select asp-for="DepartmentId"
                                        asp-items="@(ViewBag.Departments as SelectList)"
                                        class="form-select">
                                    <option value="">-- Select Department --</option>
                                </select>
                                <span asp-validation-for="DepartmentId" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label>Joining Date</label>
                                <input asp-for="JoinDate" type="date" class="form-control" />
                                <span asp-validation-for="JoinDate" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label>Salary</label>
                                <input asp-for="Salary" class="form-control" />
                                <span asp-validation-for="Salary" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label>Designation</label>
                                <input asp-for="Designation" class="form-control" />
                                <span asp-validation-for="Designation" class="text-danger"></span>
                            </div>

                            <div class="col-md-12 mb-3">
                                <label>Address</label>
                                <textarea asp-for="Address" class="form-control"></textarea>
                                <span asp-validation-for="Address" class="text-danger"></span>
                            </div>

                        </div>

                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary px-4">Update</button>
                            <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
                        </div>

                    </div>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}