

@model HRMS.Entities.Employee

<div class="container-fluid vh-100 d-flex justify-content-center align-items-start pt-5"
     style="background: linear-gradient(135deg, #1e3c72, #2a5298);">

    <div class="row shadow-lg rounded-4 overflow-hidden"
         style="width:900px; height:500px; backdrop-filter: blur(10px);">

        <!-- LEFT SIDE -->
        <div class="col-md-3 d-flex flex-column justify-content-center align-items-center text-white"
             style="background: linear-gradient(160deg, #4e73df, #224abe);">

            <div class="text-center px-3">
                <h4 class="fw-bold">
                    Empowering people, Simplifying processes
                </h4>

                <div class="mt-4">
                    <img src="~/images/logo.png" alt="logo" style="width:80px;" />
                </div>

                <p class="mt-3 small fw-semibold">HRMS SYSTEM</p>
            </div>
        </div>

        <!-- RIGHT SIDE -->
        <div class="col-md-9 d-flex justify-content-center align-items-center"
             style="background: rgba(255,255,255,0.95);">

            <div style="width:320px;">

                <div class="text-center mb-4">
                    <h3 class="fw-semibold text-dark">Employee Sign-in</h3>
                    <p class="text-muted small">Welcome back! Please login</p>
                </div>

                <form method="post" asp-action="Login">

                    <!-- Email -->
                    <div class="mb-3">
                        <input type="email" asp-for="Email"
                               class="form-control border-0 border-bottom rounded-0 shadow-none"
                               placeholder="Email" required />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <!-- Password -->
                    <div class="mb-4">
                        <input type="password" asp-for="Password"
                               class="form-control border-0 border-bottom rounded-0 shadow-none"
                               placeholder="Password" required />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <!-- Button -->
                    <button type="submit"
                            class="btn w-100 text-white fw-semibold"
                            style="background: linear-gradient(135deg, #4e73df, #224abe); border:none;">
                        Login
                    </button>

                    <!-- Error -->
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger mt-3 text-center p-2">
                            @ViewBag.Error
                        </div>
                    }

                </form>

            </div>

        </div>

    </div>
</div>