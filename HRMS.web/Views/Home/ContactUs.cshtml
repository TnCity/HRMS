@{
    ViewData["Title"] = "Contact Us";
}

<div class="container mt-5">

    <!-- 🔹 HEADER -->
    <div class="text-center mb-5">
        <h2 class="fw-bold text-primary">Contact Us</h2>
        <p class="text-muted">We’d love to hear from you. Get in touch with us!</p>
    </div>

    <div class="row">

        <!-- 🔹 CONTACT FORM -->
        <div class="col-md-6">
            <div class="card p-4 shadow-sm">

                <h5 class="mb-3">Send Message</h5>

                <form method="post" asp-action="Contact">

                    <div class="mb-3">
                        <label>Name*</label>
                        <input type="text" name="Name" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label>Email*</label>
                        <input type="email" name="Email" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label>Message*</label>
                        <textarea name="Message" class="form-control" rows="4" required></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Send Message</button>

                </form>

            </div>
        </div>

        <!-- 🔹 CONTACT INFO -->
        <div class="col-md-6">
            <div class="card p-4 shadow-sm h-100">

                <h5 class="mb-3">Contact Information</h5>

                <p><strong>📍 Address:</strong> Kolkata, India</p>
                <p><strong>📞 Phone:</strong> +91 1234567890</p>
                <p><strong>📧 Email:</strong> support@hrms.com</p>

                <hr />

                <h6>Working Hours</h6>
                <p class="mb-0">Mon - Fri: 9:00 AM - 6:00 PM</p>
                
            </div>
        </div>

    </div>

    <!-- 🔹 MAP  -->
    <div class="mt-5">
        <iframe src="https://maps.google.com/maps?q=kolkata&t=&z=13&ie=UTF8&iwloc=&output=embed"
                width="100%" height="300" style="border:0;" allowfullscreen>
        </iframe>
    </div>

</div>