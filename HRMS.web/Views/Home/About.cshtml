@{
    ViewData["Title"] = "About Us";
}

<div class="container mt-5">

    <!-- 🔹 HEADER -->
    <div class="text-center mb-5">
        <h2 class="text-primary fw-bold">About Our HRMS</h2>
        <p class="text-muted">
            Simplifying Human Resource Management with smart and efficient solutions.
        </p>
    </div>

    <!-- 🔹 COMPANY INTRO -->
    <div class="row align-items-center mb-5">
        <div class="col-md-4">
            <img src="~/images/logo.png" class="img-fluid rounded shadow" alt="HRMS Logo">
            </div>
            <div class="col-md-6">
                <h4>Who We Are</h4>
                <p>
                    Our Human Resource Management System (HRMS) is designed to streamline
                    and automate core HR processes such as employee management, attendance tracking,
                    leave handling, payroll, and reporting.
                </p>

                <p>
                    We aim to reduce manual effort, improve accuracy, and provide a seamless
                    experience for both administrators and employees.
                </p>
            </div>
        </div>

        <!-- 🔹 FEATURES -->
        <div class="mb-5">
            <h4 class="text-center mb-4">Key Features</h4>

            <div class="row text-center">

                <div class="col-md-4 mb-3">
                    <div class="card p-4 shadow-sm">
                        <h5>📅 Attendance Management</h5>
                        <p>Track employee attendance with automation and accuracy.</p>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="card p-4 shadow-sm">
                        <h5>📝 Leave Management</h5>
                        <p>Easy leave application and approval workflow.</p>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="card p-4 shadow-sm">
                        <h5>💰 Payroll System</h5>
                        <p>Generate payslips and manage salaries efficiently.</p>
                    </div>
                </div>

            </div>
        </div>

        <!-- 🔹 MISSION & VISION -->
        <div class="row text-center mb-5">

            <div class="col-md-6">
                <div class="card p-4 shadow-sm">
                    <h5>🎯 Our Mission</h5>
                    <p>
                        To provide a reliable and scalable HR solution that enhances productivity,
                        transparency, and employee satisfaction.
                    </p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card p-4 shadow-sm">
                    <h5>🚀 Our Vision</h5>
                    <p>
                        To become a leading HR technology platform empowering organizations
                        to manage their workforce efficiently.
                    </p>
                </div>
            </div>

        </div>

        <!-- 🔹 FOOTER TEXT -->
        <div class="text-center">
            <p class="text-muted">
                © 2026 HRMS. All rights reserved.
            </p>
        </div>

    </div>