@model HRMS.Entities.ContactMessage

@{
    ViewData["Title"] = "Contact Us";
}

<div class="container mt-5">

    <!-- Success Message -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["Success"]
        </div>
    }

    <!-- HEADER -->
    <div class="text-center mb-5">
        <h2 class="fw-bold text-primary">Contact Us</h2>
        <p class="text-muted">We’d love to hear from you.</p>
    </div>

    <div class="row">

        <!-- FORM -->
        <div class="col-md-6">
            <div class="card p-4 shadow-sm">

                <form asp-action="Contact" method="post">

                    <div class="mb-3">
                        <label>Name</label>
                        <input asp-for="Name" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Email</label>
                        <input asp-for="Email" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Message</label>
                        <textarea asp-for="Message" class="form-control"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Send Message
                    </button>

                </form>

            </div>
        </div>

        <!-- INFO -->
        <div class="col-md-6">
            <div class="card p-4 shadow-sm h-100">

                <h5>Contact Info</h5>

                <p><strong>📍 Address:</strong> Kolkata, India</p>
                <p><strong>📞 Phone:</strong> +91 1234567890</p>
                <p><strong>📧 Email:</strong> support@hrms.com</p>

            </div>
        </div>

    </div>

</div>